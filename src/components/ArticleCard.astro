---
interface Props {
  title: string;
  excerpt: string;
  date: string;
  slug: string;
}

const { title, excerpt, date, slug } = Astro.props;
---

<article class="border-t border-border pt-6 pb-2 group">
  <a href={`/blog/${slug}`} class="block">
    <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-2 md:gap-8">
      <div class="flex-1">
        <h3 class="text-lg font-heading font-semibold text-foreground group-hover:text-primary transition-colors mb-1.5">
          {title}
        </h3>
        <p class="text-sm text-muted-foreground leading-relaxed">{excerpt}</p>
      </div>
      <div class="flex items-center gap-3 shrink-0">
        <time class="text-xs font-mono text-muted-foreground whitespace-nowrap">{date}</time>
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="text-muted-foreground group-hover:text-primary transition-colors"
          aria-hidden="true"
        >
          <path d="M5 12h14"/>
          <path d="m12 5 7 7-7 7"/>
        </svg>
      </div>
    </div>
  </a>
</article>
