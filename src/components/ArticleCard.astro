---
interface Props {
  title: string;
  excerpt: string;
  date: string;
  slug: string;
}

const { title, excerpt, date, slug } = Astro.props;
---

<a
  href={`/blog/${slug}`}
  class="group block py-8 border-b border-border px-4 -mx-4 rounded-xl hover:bg-white hover:shadow-sm transition-all duration-200"
>
  <div class="flex justify-between items-start mb-3 gap-4">
    <h3 class="text-lg sm:text-xl font-semibold text-foreground group-hover:text-muted-foreground transition-colors leading-snug pr-8">
      {title}
    </h3>
    <div class="flex items-center gap-4 flex-shrink-0 mt-1">
      {date && (
        <time class="text-sm font-mono text-muted-foreground whitespace-nowrap">{date}</time>
      )}
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="text-border group-hover:text-foreground group-hover:translate-x-1 transition-all"
        aria-hidden="true"
      >
        <line x1="5" y1="12" x2="19" y2="12"/>
        <polyline points="12 5 19 12 12 19"/>
      </svg>
    </div>
  </div>
  <p class="text-muted-foreground text-sm sm:text-base leading-relaxed max-w-3xl pr-12">{excerpt}</p>
</a>
