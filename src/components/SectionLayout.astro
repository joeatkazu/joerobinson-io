---
interface Props {
  title?: string;
  subtitle?: string;
  class?: string;
  id?: string;
}

const { title, subtitle, class: className = '', id } = Astro.props;
---

<section class:list={['py-24 md:py-32', className]} id={id}>
  <div class="container max-w-4xl">
    {(title || subtitle) && (
      <div class="mb-12">
        {title && (
          <span class="font-mono text-xs font-semibold tracking-[0.2em] text-muted-foreground uppercase mb-4 block">{title}</span>
        )}
        {subtitle && (
          <h2 class="text-3xl sm:text-4xl font-bold text-foreground tracking-tight">{subtitle}</h2>
        )}
      </div>
    )}
    <slot />
  </div>
</section>
