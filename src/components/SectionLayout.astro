---
interface Props {
  title?: string;
  subtitle?: string;
  class?: string;
  id?: string;
}

const { title, subtitle, class: className = '', id } = Astro.props;
---

<section class:list={['py-16 md:py-20', className]} id={id}>
  <div class="container">
    {(title || subtitle) && (
      <div class="mb-10 md:mb-12">
        {title && (
          <h2 class="text-sm font-mono text-primary uppercase tracking-wide mb-2">{title}</h2>
        )}
        {subtitle && (
          <p class="text-2xl md:text-3xl font-heading font-semibold text-foreground">{subtitle}</p>
        )}
      </div>
    )}
    <slot />
  </div>
</section>
