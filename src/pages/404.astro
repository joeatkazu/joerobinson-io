---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
---

<BaseLayout title="Page not found — Joe Robinson">
  <SiteHeader />
  <div class="py-20">
    <div class="container">
      <p class="text-sm font-mono text-primary mb-4 uppercase tracking-wide">404</p>
      <h1 class="mb-4">Page not found</h1>
      <p class="text-muted-foreground leading-relaxed max-w-md mb-8">
        The page you're looking for doesn't exist or has been moved.
      </p>
      <a
        href="/"
        class="inline-flex items-center gap-2 text-sm font-medium text-primary hover:text-foreground transition-colors group"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="m12 19-7-7 7-7"/>
          <path d="M19 12H5"/>
        </svg>
        Back to home
      </a>
    </div>
  </div>
  <SiteFooter />
</BaseLayout>
