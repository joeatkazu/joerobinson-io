---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import SectionLayout from '../../components/SectionLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';

const allPosts = await getCollection('blog');
const articles = allPosts.sort((a, b) => {
  const dateA = a.data.publishedDate ?? a.data.published ?? '';
  const dateB = b.data.publishedDate ?? b.data.published ?? '';
  return new Date(dateB).getTime() - new Date(dateA).getTime();
});
---

<BaseLayout
  title="Blog — Joe Robinson"
  description="Writing on SEO, growth, and operations."
>
  <SiteHeader />
  <SectionLayout title="Blog" subtitle="Writing on SEO, growth, and operations">
    <div class="space-y-2 max-w-3xl">
      {articles.map((post) => (
        <ArticleCard
          title={post.data.title}
          excerpt={post.data.description}
          date={post.data.publishedDate ?? post.data.published ?? ''}
          slug={post.slug}
        />
      ))}
    </div>
  </SectionLayout>
  <SiteFooter />
</BaseLayout>
