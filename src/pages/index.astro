---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import Hero from '../components/Hero.astro';
import SectionLayout from '../components/SectionLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';

const tools = [
  { name: 'Schema Markup Generator', url: '/tools' },
  { name: 'Core Web Vitals Checker', url: '/tools' },
  { name: 'Internal Link Analyzer', url: '/tools' },
];

const allPosts = await getCollection('blog');
const recentArticles = allPosts
  .sort((a, b) => {
    const dateA = a.data.publishedDate ?? a.data.published ?? '';
    const dateB = b.data.publishedDate ?? b.data.published ?? '';
    return new Date(dateB).getTime() - new Date(dateA).getTime();
  })
  .slice(0, 3);
---

<BaseLayout>
  <SiteHeader />

  <Hero />

  <div class="border-t border-border"></div>

  <SectionLayout title="Results" subtitle="Recent results">
    <ul class="space-y-0 mb-8 max-w-2xl">
      <li class="border-t border-border pt-4 pb-4">
        <span class="font-semibold text-foreground">+40% monthly MQLs</span>
        <span class="text-muted-foreground"> after rebuilding organic acquisition and content strategy</span>
      </li>
      <li class="border-t border-border pt-4 pb-4">
        <span class="font-semibold text-foreground">€250k ARR customer</span>
        <span class="text-muted-foreground"> influenced by SEO-led discovery and content positioning</span>
      </li>
      <li class="border-t border-border pt-4 pb-4">
        <span class="font-semibold text-foreground">+300% organic traffic</span>
        <span class="text-muted-foreground"> in 7 months for a B2B SaaS client after fixing foundations and scaling content</span>
      </li>
      <li class="border-t border-border pt-4 pb-4">
        <span class="font-semibold text-foreground">80% reduction in SEO operating costs</span>
        <span class="text-muted-foreground"> while increasing output 50% through improved SOPs and team restructuring</span>
      </li>
      <li class="border-t border-border pt-4 pb-4">
        <span class="font-semibold text-foreground">Scalable programmatic content infrastructure</span>
        <span class="text-muted-foreground"> — 600k+ pages, serving thousands of daily visits</span>
      </li>
    </ul>
    <p class="text-muted-foreground leading-relaxed max-w-2xl">
      These results come from fixing the same underlying issues: unclear priorities, weak execution systems, and organic growth that isn't tied closely enough to the business.
    </p>
  </SectionLayout>

  <div class="border-t border-border"></div>

  <SectionLayout title="How I work">
    <div class="space-y-6 max-w-2xl">
      <div>
        <p class="font-semibold text-foreground mb-1">Strategy is a commodity; execution is the moat.</p>
        <p class="text-muted-foreground leading-relaxed">Most SEO strategies fail at implementation. I focus on the mechanics — site architecture, internal linking, content operations, QA — because that's where the compound returns are hidden.</p>
      </div>
      <div>
        <p class="font-semibold text-foreground mb-1">Efficiency over effort.</p>
        <p class="text-muted-foreground leading-relaxed">I once replaced a 10-person manual link-building team with a 4-person system-led team. We spent €14k less per month and grew traffic by 1.3 million sessions. Better systems beat more people.</p>
      </div>
      <div>
        <p class="font-semibold text-foreground mb-1">Skin in the game.</p>
        <p class="text-muted-foreground leading-relaxed">I've built my own media properties from scratch and know what it costs when content doesn't rank. I use AI to operationalise processes and speed up execution — with human oversight on everything that matters.</p>
      </div>
    </div>
  </SectionLayout>

  <div class="border-t border-border"></div>

  <SectionLayout title="Services" subtitle="How we can work together">
    <div class="space-y-4 max-w-2xl">
      <div class="border border-border rounded-lg p-6">
        <h3 class="font-heading font-semibold text-foreground mb-2">SEO Audit & Alignment</h3>
        <p class="text-muted-foreground leading-relaxed mb-3">If your organic traffic has plateaued or your agency is reporting on rankings while your pipeline is flat, you have an alignment problem. I find the 3–5 technical or structural levers that are actually holding you back and work with your team to pull them.</p>
        <p class="text-sm text-muted-foreground"><span class="font-medium text-foreground">Best for:</span> Teams with a legacy SEO setup that has stopped performing.</p>
      </div>
      <div class="border border-border rounded-lg p-6">
        <h3 class="font-heading font-semibold text-foreground mb-2">Fractional SEO Leadership</h3>
        <p class="text-muted-foreground leading-relaxed mb-3">Most marketing leaders don't have time to audit their SEO agency's work. I act as your internal advocate — managing external vendors, setting KPIs tied to MQLs and pipeline, and holding them accountable to performance.</p>
        <p class="text-sm text-muted-foreground"><span class="font-medium text-foreground">Best for:</span> Marketing leaders who suspect their agency is underdelivering.</p>
      </div>
      <div class="border border-border rounded-lg p-6">
        <h3 class="font-heading font-semibold text-foreground mb-2">AI-Augmented Content Operations</h3>
        <p class="text-muted-foreground leading-relaxed mb-3">AI makes content cheap, but quality is becoming the differentiator. I build editorial workflows that use LLMs for research, clustering, and first drafts — with human oversight on the points that matter. The result is substantially higher output at a fraction of traditional cost.</p>
        <p class="text-sm text-muted-foreground"><span class="font-medium text-foreground">Best for:</span> Teams that need to scale content without scaling headcount.</p>
      </div>
    </div>
  </SectionLayout>

  <div class="border-t border-border"></div>

  <SectionLayout title="Writing" subtitle="Recent thinking">
    <div class="space-y-2">
      {recentArticles.map((post) => (
        <ArticleCard
          title={post.data.title}
          excerpt={post.data.description}
          date={post.data.publishedDate ?? post.data.published ?? ''}
          slug={post.slug}
        />
      ))}
    </div>
    <div class="mt-8">
      <a
        href="/blog"
        class="inline-flex items-center gap-2 text-sm font-medium text-primary hover:text-foreground transition-colors group"
      >
        All articles
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="transition-transform group-hover:translate-x-0.5"
          aria-hidden="true"
        >
          <path d="M5 12h14"/>
          <path d="m12 5 7 7-7 7"/>
        </svg>
      </a>
    </div>
  </SectionLayout>

  <div class="border-t border-border"></div>

  <SectionLayout title="Tools" subtitle="Useful resources">
    <div class="flex flex-wrap gap-4">
      {tools.map((tool) => (
        <a
          href={tool.url}
          class="text-sm text-muted-foreground hover:text-primary transition-colors border border-border rounded-md px-4 py-2"
        >
          {tool.name}
        </a>
      ))}
    </div>
  </SectionLayout>

  <section class="py-16 md:py-20 border-t border-border">
    <div class="container max-w-2xl text-center">
      <h2 class="text-2xl md:text-3xl font-heading font-semibold text-foreground mb-4">Let's talk.</h2>
      <p class="text-muted-foreground leading-relaxed">
        If you want sustainable, measurable growth, or you're hiring someone to lead it,{' '}
        <a href="/contact" class="text-primary hover:text-foreground transition-colors underline underline-offset-2">start a conversation</a>
        {' '}or connect with me on{' '}
        <a
          href="https://www.linkedin.com/in/robinson-j/"
          class="text-primary hover:text-foreground transition-colors underline underline-offset-2"
          target="_blank"
          rel="noopener noreferrer"
        >LinkedIn</a>.
      </p>
    </div>
  </section>

  <SiteFooter />
</BaseLayout>
