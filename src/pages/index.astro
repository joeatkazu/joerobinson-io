---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import Hero from '../components/Hero.astro';
import SectionLayout from '../components/SectionLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';

const tools = [
  { name: 'Schema Markup Generator', url: '/tools' },
  { name: 'Core Web Vitals Checker', url: '/tools' },
  { name: 'Internal Link Analyzer', url: '/tools' },
];

const allPosts = await getCollection('blog');
const recentArticles = allPosts
  .sort((a, b) => {
    const dateA = a.data.publishedDate ?? a.data.published ?? '';
    const dateB = b.data.publishedDate ?? b.data.published ?? '';
    return new Date(dateB).getTime() - new Date(dateA).getTime();
  })
  .slice(0, 3);
---

<BaseLayout>
  <SiteHeader />

  <Hero />

  <div class="w-full h-px bg-border"></div>

  <SectionLayout title="Results" subtitle="Recent results" class="bg-secondary">
    <ul class="flex flex-col w-full border-t border-border mb-12">
      <li class="py-6 border-b border-border text-base sm:text-lg text-muted-foreground leading-relaxed hover:bg-muted/50 transition-colors px-4 -mx-4 rounded-lg">
        <strong class="font-semibold text-foreground">+40% monthly MQLs</strong>
        {' '}after rebuilding organic acquisition and content strategy
      </li>
      <li class="py-6 border-b border-border text-base sm:text-lg text-muted-foreground leading-relaxed hover:bg-muted/50 transition-colors px-4 -mx-4 rounded-lg">
        <strong class="font-semibold text-foreground">€250k ARR customer</strong>
        {' '}influenced by SEO-led discovery and content positioning
      </li>
      <li class="py-6 border-b border-border text-base sm:text-lg text-muted-foreground leading-relaxed hover:bg-muted/50 transition-colors px-4 -mx-4 rounded-lg">
        <strong class="font-semibold text-foreground">+300% organic traffic</strong>
        {' '}in 7 months for a B2B SaaS client after fixing foundations and scaling content
      </li>
      <li class="py-6 border-b border-border text-base sm:text-lg text-muted-foreground leading-relaxed hover:bg-muted/50 transition-colors px-4 -mx-4 rounded-lg">
        <strong class="font-semibold text-foreground">80% reduction in SEO operating costs</strong>
        {' '}while increasing output 50% through improved SOPs and team restructuring
      </li>
      <li class="py-6 border-b border-border text-base sm:text-lg text-muted-foreground leading-relaxed hover:bg-muted/50 transition-colors px-4 -mx-4 rounded-lg">
        <strong class="font-semibold text-foreground">Scalable programmatic content infrastructure</strong>
        {': '}600k+ pages, serving thousands of daily visits
      </li>
    </ul>
    <p class="text-muted-foreground leading-relaxed max-w-3xl text-base sm:text-lg">
      These results come from fixing the same underlying issues: unclear priorities, weak execution systems, and organic growth that isn't tied closely enough to the business.
    </p>
  </SectionLayout>

  <div class="w-full h-px bg-border"></div>

  <SectionLayout title="How I work">
    <div class="space-y-6 max-w-3xl text-base sm:text-lg">
      <div>
        <p class="font-semibold text-foreground mb-1">SEO execution</p>
        <p class="text-muted-foreground leading-relaxed">Good strategies fail when executed poorly. You need to fix the mechanics involved in making a website work properly - architecture and internal linking, rendering and indexability, content operations, QA, accessibility, compliance.</p>
      </div>
      <div>
        <p class="font-semibold text-foreground mb-1">Better operations</p>
        <p class="text-muted-foreground leading-relaxed">A well built and properly documented system used by an agile team beats a larger team using inefficient methodologies every time. I built a team that reduced spend by 80% whilst achieving 2x on KPIs.</p>
      </div>
      <div>
        <p class="font-semibold text-foreground mb-1">Skin in the game</p>
        <p class="text-muted-foreground leading-relaxed">I've built websites from scratch and know what it costs when growth stalls. I care deeply about building robust, reliable, and accurate campaigns that make SEO a solid long-term financial success.</p>
      </div>
    </div>
  </SectionLayout>

  <div class="w-full h-px bg-border"></div>

  <SectionLayout title="Services" subtitle="How we can work together" class="bg-secondary">
    <div class="space-y-4 max-w-3xl">
      <div class="border border-border rounded-lg p-6">
        <h3 class="font-semibold text-foreground mb-2">SEO Audit & Alignment</h3>
        <p class="text-muted-foreground leading-relaxed mb-3">If your organic traffic has plateaued or your agency is reporting on rankings while your pipeline is flat, you have an alignment problem. I find the 3–5 technical or structural levers that are actually holding you back and work with your team to pull them.</p>
        <p class="text-sm text-muted-foreground"><span class="font-medium text-foreground">Best for:</span> Teams with a legacy SEO setup that has stopped performing.</p>
      </div>
      <div class="border border-border rounded-lg p-6">
        <h3 class="font-semibold text-foreground mb-2">Fractional SEO Leadership</h3>
        <p class="text-muted-foreground leading-relaxed mb-3">Most marketing leaders don't have time to audit their SEO agency's work. I act as your internal advocate: managing external vendors, setting KPIs tied to MQLs and pipeline, and holding them accountable to performance.</p>
        <p class="text-sm text-muted-foreground"><span class="font-medium text-foreground">Best for:</span> Marketing leaders who suspect their agency is underdelivering.</p>
      </div>
      <div class="border border-border rounded-lg p-6">
        <h3 class="font-semibold text-foreground mb-2">AI-Augmented Content Operations</h3>
        <p class="text-muted-foreground leading-relaxed mb-3">AI makes content cheap, but quality is becoming the differentiator. I build editorial workflows that use LLMs for research, clustering, and first drafts: with human oversight on the points that matter. The result is substantially higher output at a fraction of traditional cost.</p>
        <p class="text-sm text-muted-foreground"><span class="font-medium text-foreground">Best for:</span> Teams that need to scale content without scaling headcount.</p>
      </div>
    </div>
  </SectionLayout>

  <div class="w-full h-px bg-border"></div>

  <SectionLayout title="Blog" subtitle="Recent posts">
    <div class="flex flex-col w-full border-t border-border">
      {recentArticles.map((post) => (
        <ArticleCard
          title={post.data.title}
          excerpt={post.data.description}
          date={post.data.publishedDate ?? post.data.published ?? ''}
          slug={post.slug}
        />
      ))}
    </div>
    <div class="mt-10">
      <a
        href="/blog"
        class="inline-flex items-center gap-2 text-muted-foreground font-medium hover:text-foreground transition-colors group text-sm"
      >
        All articles
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="group-hover:translate-x-1 transition-transform"
          aria-hidden="true"
        >
          <line x1="5" y1="12" x2="19" y2="12"/>
          <polyline points="12 5 19 12 12 19"/>
        </svg>
      </a>
    </div>
  </SectionLayout>

  <div class="w-full h-px bg-border"></div>

  <SectionLayout title="Tools" subtitle="Useful resources" class="bg-secondary">
    <div class="flex flex-wrap gap-4">
      {tools.map((tool) => (
        <a
          href={tool.url}
          class="text-sm text-muted-foreground hover:text-foreground transition-colors border border-border rounded-md px-4 py-2 bg-white"
        >
          {tool.name}
        </a>
      ))}
    </div>
  </SectionLayout>

  <div class="w-full h-px bg-border"></div>

  <section class="py-24 md:py-32">
    <div class="container max-w-4xl text-center">
      <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-foreground mb-4">Let's talk.</h2>
      <p class="text-muted-foreground leading-relaxed text-base sm:text-lg">
        If you want sustainable, measurable growth, or you're hiring someone to lead it,{' '}
        <a href="/contact" class="text-foreground hover:text-muted-foreground transition-colors underline underline-offset-2">start a conversation</a>
        {' '}or connect with me on{' '}
        <a
          href="https://www.linkedin.com/in/robinson-j/"
          class="text-foreground hover:text-muted-foreground transition-colors underline underline-offset-2"
          target="_blank"
          rel="noopener noreferrer"
        >LinkedIn</a>.
      </p>
    </div>
  </section>

  <SiteFooter />
</BaseLayout>
